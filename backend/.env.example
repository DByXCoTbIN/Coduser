# Brauser IDE Backend Configuration

# App settings
APP_NAME=Brauser IDE Backend
APP_VERSION=1.0.0
DEBUG=false

# Server settings
HOST=0.0.0.0
PORT=8000

# CORS settings
CORS_ORIGINS=["*"]

# Database settings (MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=

# Apache settings
APACHE_PORT=80
APACHE_DOCUMENT_ROOT=./public

# PHP settings
PHP_PORT=9000

# Git settings
GIT_DEFAULT_BRANCH=main

# File system settings
WORKSPACE_ROOT=~/brauser-workspace
MAX_FILE_SIZE=10485760

# Security settings
SECRET_KEY=your-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30